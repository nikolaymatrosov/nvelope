# Copy to .env and adjust. Consumed by all nvelope services and the migrate CLI.
# Every variable is prefixed NVELOPE_.

# Required. Runtime PostgreSQL DSN — connects as the restricted nvelope_app role
# (non-superuser, non-BYPASSRLS) so RLS policies always apply. Secret — never logged.
NVELOPE_DATABASE_URL=postgres://nvelope_app:nvelope_app@localhost:5432/nvelope?sslmode=disable

# Optional. Privileged PostgreSQL DSN used ONLY by the migrate CLI (DDL + role
# management). Falls back to NVELOPE_DATABASE_URL when unset. Secret — never logged.
NVELOPE_MIGRATE_DATABASE_URL=postgres://nvelope:nvelope@localhost:5432/nvelope?sslmode=disable

# Optional. One of: debug, info, warn, error. Default: info.
NVELOPE_LOG_LEVEL=info

# Optional. Listen address for the API service. Default: :8080.
NVELOPE_HTTP_ADDR=:8080

# Optional. Graceful-shutdown drain bound (Go duration). Default: 10s.
NVELOPE_SHUTDOWN_TIMEOUT=10s

# Optional. Platform login session lifetime (Go duration). Default: 168h.
NVELOPE_SESSION_TTL=168h

# Optional. Team invitation lifetime (Go duration). Default: 168h.
NVELOPE_INVITE_TTL=168h

# Optional. Externally reachable base URL, used to build invitation acceptance
# links and campaign tracking links. Default: http://localhost:8080.
NVELOPE_BASE_URL=http://localhost:8080

# --- Phase 3: Sending pipeline ---------------------------------------------

# Required. Redis DSN for cross-pod sliding-window rate-limit counters.
# Secret — never logged.
NVELOPE_REDIS_URL=redis://localhost:6379/0

# Required. Yandex Postbox (SES-compatible) connection settings.
NVELOPE_POSTBOX_REGION=ru-central1
NVELOPE_POSTBOX_ENDPOINT=https://postbox.cloud.yandex.net
# Secret — never logged.
NVELOPE_POSTBOX_ACCESS_KEY_ID=
NVELOPE_POSTBOX_SECRET_ACCESS_KEY=

# Optional. River queue name the campaign/domain send workers consume.
# Default: sending.
NVELOPE_WORKER_SEND_QUEUE=sending

# Optional. Platform-wide sliding-window send cap protecting the shared Postbox
# account. Default: 500 sends per 1s.
NVELOPE_GLOBAL_SEND_RATE_LIMIT=500
NVELOPE_GLOBAL_SEND_RATE_WINDOW=1s

# Optional. Per-tenant send rate applied until plan-derived limits exist
# (Phase 5). Default: 50 sends per 1s.
NVELOPE_DEFAULT_TENANT_SEND_RATE_LIMIT=50
NVELOPE_DEFAULT_TENANT_SEND_RATE_WINDOW=1s

# Optional. Sending-domain verification polling cadence and the maximum window
# after which a still-unverified domain is marked failed. Defaults: 15m, 72h.
NVELOPE_SENDING_DOMAIN_VERIFY_INTERVAL=15m
NVELOPE_SENDING_DOMAIN_VERIFY_WINDOW=72h

# Optional. Number of recipients per campaign.batch job. Default: 500.
NVELOPE_CAMPAIGN_BATCH_SIZE=500

# --- Phase 4: Deliverability & analytics -----------------------------------

# Required. The Yandex Data Streams topic Postbox writes delivery feedback to,
# consumed by cmd/consumer. Postbox does not call a webhook — feedback arrives
# only via this stream.
NVELOPE_FEEDBACK_STREAM_ENDPOINT=grpcs://ydb.serverless.yandexcloud.net:2135
NVELOPE_FEEDBACK_STREAM_DATABASE=/ru-central1/b1g000000000000000/etn000000000000000
NVELOPE_FEEDBACK_STREAM_TOPIC=postbox-feedback
NVELOPE_FEEDBACK_STREAM_CONSUMER=nvelope-consumer

# Optional. Yandex Cloud service-account key JSON file used to authenticate to
# the feedback stream. Empty uses the instance IAM metadata credentials (the
# workload's bound service account). Secret — never logged.
NVELOPE_FEEDBACK_STREAM_CREDENTIALS_FILE=

# Optional. How often the scheduler enqueues an analytics.refresh job per
# active tenant (Go duration). Default: 60s.
NVELOPE_ANALYTICS_REFRESH_INTERVAL=60s
